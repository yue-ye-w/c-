#include <stdio.h>

int fun(int a[3][3])
{
    int sum = 0;

    for (int j = 0; j < 3; j++)
    {
        sum += a[0][j];
        sum += a[2][j];
    }

    return sum;
}

int main(void)
{
    int a[3][3];
    int sum;

    printf("input a 3*3 matrix:\n");

    for (int i = 0; i < 3; i++)
    {
        for (int j = 0; j < 3; j++)
        {
            scanf("%d", &a[i][j]);
        }
    }

    sum = fun(a);

    printf("Sum=%d\n", sum);

    return 0;
}
